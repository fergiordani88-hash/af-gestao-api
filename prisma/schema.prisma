// AF Gestão & Consultoria — Schema Prisma
// SQLite para desenvolvimento local | PostgreSQL para produção (Supabase)
// Troca automática via DATABASE_URL no .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("CONSULTOR")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients          Client[]          @relation("Responsible")
  diagnosticosPJ   DiagnosticoPJ[]
  diagnosticosAgro DiagnosticoAgro[]
  actionPlans      ActionPlan[]
}

model Client {
  id            String   @id @default(cuid())
  name          String
  document      String   @unique
  phone         String
  email         String
  city          String
  state         String   @default("MT")
  address       String?
  zipCode       String?
  segment       String
  size          String   @default("MEDIA")
  revenue       Float    @default(0)
  status        String   @default("LEAD")
  notes         String?
  responsibleId String
  responsible   User     @relation("Responsible", fields: [responsibleId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contacts         Contact[]
  attendances      Attendance[]
  contracts        Contract[]
  diagnosticosPJ   DiagnosticoPJ[]
  diagnosticosAgro DiagnosticoAgro[]
  actionPlans      ActionPlan[]
  creditOps        CreditOperation[]
  cashFlows        CashFlow[]
  documents        Document[]
  agroProducoes    AgroProducao[]
  agroContratos    AgroContrato[]
  agroDespesas     AgroDespesa[]
  agroReceitas     AgroReceita[]
  agroCustosFixos  AgroCustoFixo[]
  agroPatrimonios  AgroPatrimonio[]
  pjDres           PJDre[]
  pjRecebimentos   PJRecebimento[]
  pjPagamentos     PJPagamento[]
  pjContratos      PJContrato[]
  pjDespesas       PJDespesa[]
  pjReceitas       PJReceita[]
  pjCustosFixos    PJCustoFixo[]
  pjStressTests           PJStressTest[]
  pjHistoricoIndicadores  PJHistoricoIndicadores[]
  pjInadimplencias        PJInadimplencia[]
  agroHistoricoSafras     AgroHistoricoSafra[]
  agroDRERurais           AgroDRERural[]
  questionarioPJ          QuestionarioPJ?
  questionarioAgro        QuestionarioAgro?
  metas                   Meta[]
  pjDreProjetados         PJDreProjetado[]
}

model Contact {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name     String
  role     String?
  phone    String?
  email    String?
  primary  Boolean @default(false)
}

model Attendance {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date      DateTime
  type      String
  summary   String
  nextSteps String?
  createdAt DateTime @default(now())
}

model Contract {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  plan         String
  description  String?
  monthlyValue Float
  setupFee     Float?
  startDate    DateTime
  renewalDate  DateTime
  status       String   @default("ATIVO")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DiagnosticoPJ {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  consultorId String
  consultor   User     @relation(fields: [consultorId], references: [id])
  period      String
  segment     String?
  employees   Int?

  grossRevenue      Float @default(0)
  deductions        Float @default(0)
  cmv               Float @default(0)
  fixedExpenses     Float @default(0)
  variableExpenses  Float @default(0)
  financialExpenses Float @default(0)
  proLabore         Float @default(0)
  totalDebt         Float @default(0)
  shortTermDebt     Float @default(0)
  bankName          String?

  hasAccounting       Boolean @default(false)
  hasERP              Boolean @default(false)
  hasFinancialControl Boolean @default(false)

  classification String?
  grossMargin    Float?
  netMargin      Float?
  ebitda         Float?
  breakeven      Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actionPlans ActionPlan[]
  documents   Document[]
}

model DiagnosticoAgro {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  consultorId String
  consultor   User     @relation(fields: [consultorId], references: [id])
  season      String

  ownArea      Float @default(0)
  leasedArea   Float @default(0)
  leaseValueHa Float @default(0)
  cultures     String

  custeioValue Float  @default(0)
  custeioBank  String?
  custeioRate  Float  @default(0)
  investValue  Float  @default(0)
  investBank   String?
  investRate   Float  @default(0)
  cprValue     Float  @default(0)
  cprBank      String?

  propertyValue  Float @default(0)
  machineryValue Float @default(0)

  hasInsurance     Boolean @default(false)
  hasPlanning      Boolean @default(false)
  hasFinancialCtrl Boolean @default(false)

  classification String?
  totalRevenue   Float?
  totalCost      Float?
  margin         Float?
  revenueHa      Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actionPlans ActionPlan[]
  documents   Document[]
}

model CashFlow {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  year        Int
  month       Int
  type        String
  category    String
  description String
  value       Float
  dueDate     DateTime
  paidDate    DateTime?
  status      String    @default("PENDENTE")
  createdAt   DateTime  @default(now())
}

model CreditOperation {
  id         String    @id @default(cuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id])
  bank       String
  creditLine String
  value      Float
  rate       Float
  termMonths Int
  guarantees String?
  startDate  DateTime?
  status     String    @default("ANALISE")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ActionPlan {
  id                String           @id @default(cuid())
  clientId          String
  client            Client           @relation(fields: [clientId], references: [id])
  consultorId       String
  consultor         User             @relation(fields: [consultorId], references: [id])
  diagnosticoPJId   String?
  diagnosticoPJ     DiagnosticoPJ?   @relation(fields: [diagnosticoPJId], references: [id])
  diagnosticoAgroId String?
  diagnosticoAgro   DiagnosticoAgro? @relation(fields: [diagnosticoAgroId], references: [id])

  area           String
  action         String
  objective      String
  priority       String   @default("MEDIA")
  deadline       DateTime
  responsible    String
  expectedResult String
  status         String   @default("NAO_INICIADO")
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id                String           @id @default(cuid())
  clientId          String
  client            Client           @relation(fields: [clientId], references: [id])
  diagnosticoPJId   String?
  diagnosticoPJ     DiagnosticoPJ?   @relation(fields: [diagnosticoPJId], references: [id])
  diagnosticoAgroId String?
  diagnosticoAgro   DiagnosticoAgro? @relation(fields: [diagnosticoAgroId], references: [id])
  name              String
  type              String
  url               String?
  size              Int?
  status            String   @default("RASCUNHO")
  createdAt         DateTime @default(now())
}

// ─────────────────────────────────────────────
// MÓDULO AGRO COMPLETO
// ─────────────────────────────────────────────

// Produção histórica (triênio) + previsão
model AgroProducao {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  safra     String   // ex: "2023/24", "2024/25", "2025/26"
  tipo      String   // "historico" | "previsao"
  cultura   String   // "Soja" | "Milho 2a" | "Algodao" etc
  ordem     String   // "principal" | "segunda"
  cotacao   Float    @default(0)
  area      Float    @default(0)
  produtividade Float @default(0)
  custoPorHa    Float @default(0)
  areaArrendada Float @default(0)
  custoArrendHa Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contratos de crédito individuais
model AgroContrato {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  modalidade    String   // Capital de giro, Repactuação, Investimento CDI, BNDES Finame, Custeio, CPR etc
  banco         String
  numeroContrato String?
  dataContratacao DateTime
  valorTomado   Float
  totalParcelas Int
  parcelaAtual  Int
  periodicidade String   // Mensal | Anual | Semestral | Trimestral | Único
  taxa          Float    // % ao período
  vencimento    DateTime // data do próximo vencimento
  valorParcela  Float
  obs           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Despesas não bancárias
model AgroDespesa {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  data      DateTime
  tipo      String   // Salários | Custo da atividade | Investimento | Cartão de crédito | Contas comércio | Previsões | Outros
  origem    String
  descricao String
  valor     Float
  createdAt DateTime @default(now())
}

// Receitas
model AgroReceita {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  data      DateTime
  origem    String
  tipo      String   // Recebimento | Antecipação | CPR | Outros
  descricao String
  valor     Float
  createdAt DateTime @default(now())
}

// Custos fixos por categoria
model AgroCustoFixo {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  categoria String   // Custos recorrentes | Folha | Contábil | Tecnologia | Marketing | Operacional | Bancário | Consórcios
  item      String
  valorMensal Float  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Patrimônio
model AgroPatrimonio {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  categoria     String   // Máquinas | Equipamentos | Veículos | Imóveis rurais | Imóveis urbanos | Rebanho
  descricao     String
  identificacao String?
  valorAvaliado Float    @default(0)
  possuiOnus    Boolean  @default(false)
  tipoOnus      String?
  credor        String?
  valorOnus     Float    @default(0)
  obs           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────
// MÓDULO PJ COMPLETO
// ─────────────────────────────────────────────

// Snapshot do DRE (entradas do formulário)
model PJDre {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  periodo   String   @default("mensal") // mensal | anual

  // Entradas
  receitaBruta        Float @default(0)
  cmv                 Float @default(0)
  despesasFixas       Float @default(0)
  folha               Float @default(0)
  proLabore           Float @default(0)
  tributos            Float @default(0)
  despesasFinanceiras Float @default(0)
  parcela             Float @default(0)

  // Ativos / passivos
  caixa               Float @default(0)
  aReceber            Float @default(0)
  estoque             Float @default(0)
  aFornecedores       Float @default(0)
  dividaTotal         Float @default(0)
  dividaCP            Float @default(0) // curto prazo

  // Premissas extras
  diasEstoque         Float @default(30)
  lucroInformadoSocio Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Formas de recebimento
model PJRecebimento {
  id          String  @id @default(cuid())
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  forma       String  // Boleto | Cartão débito | Cartão crédito | PIX | Dinheiro | Cheque | Crediário
  percentual  Float   @default(0) // % das vendas
  prazoMedio  Int     @default(0) // dias
  parcelas    Int     @default(1)
  obs         String?
  createdAt   DateTime @default(now())
}

// Formas de pagamento a fornecedores
model PJPagamento {
  id          String  @id @default(cuid())
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  forma       String  // Boleto/prazo | Transferência | Cartão/antecipado | À vista/PIX
  percentual  Float   @default(0)
  prazoMedio  Int     @default(0)
  parcelas    Int     @default(1)
  obs         String?
  createdAt   DateTime @default(now())
}

// Contratos PJ (mesma estrutura do Agro)
model PJContrato {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  modalidade      String
  banco           String
  numeroContrato  String?
  dataContratacao DateTime
  valorTomado     Float
  totalParcelas   Int
  parcelaAtual    Int
  periodicidade   String
  taxa            Float
  vencimento      DateTime
  valorParcela    Float
  obs             String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Despesas PJ
model PJDespesa {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  data      DateTime
  tipo      String
  origem    String
  descricao String
  valor     Float
  createdAt DateTime @default(now())
}

// Receitas PJ
model PJReceita {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  data      DateTime
  origem    String
  tipo      String
  descricao String
  valor     Float
  createdAt DateTime @default(now())
}

// Custos fixos PJ
model PJCustoFixo {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  categoria   String
  item        String
  valorMensal Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Premissas do Stress Test
model PJStressTest {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  variacaoQueda   Float    @default(-0.3)  // ex: -0.3 = -30%
  variacaoAlta    Float    @default(0.3)
  pctCustoVar     Float    @default(0.48)  // % custo variável / receita
  pctDespFixaVar  Float    @default(0.05)  // % despesa fixa que varia com vendas
  saldoInicial    Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────
// HISTÓRICO DE INDICADORES (PJ + Agro)
// ─────────────────────────────────────────────

// Snapshot mensal dos indicadores PJ
model PJHistoricoIndicadores {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  periodo   String   // "2025-01", "2025-02" etc
  ano       Int
  mes       Int

  // DRE
  receitaBruta        Float @default(0)
  cmv                 Float @default(0)
  despesasFixas       Float @default(0)
  folha               Float @default(0)
  proLabore           Float @default(0)
  tributos            Float @default(0)
  despesasFinanceiras Float @default(0)
  parcela             Float @default(0)

  // Calculados e salvos
  lucBruto    Float @default(0)
  ebitda      Float @default(0)
  lucLiq      Float @default(0)
  sobraCaixa  Float @default(0)
  margBruta   Float @default(0)
  margEbitda  Float @default(0)
  margLiq     Float @default(0)
  liquidezC   Float @default(0)
  cobDivida   Float @default(0)
  ncg         Float @default(0)
  peBS        Float @default(0)
  classificacao String @default("atencao")

  // Balanço
  caixa       Float @default(0)
  aReceber    Float @default(0)
  estoque     Float @default(0)
  dividaTotal Float @default(0)

  createdAt DateTime @default(now())

  @@unique([clientId, periodo])
}

// Snapshot de safra Agro
model AgroHistoricoSafra {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  safra     String   // "2023/24", "2024/25"
  tipo      String   // "historico" | "previsao"

  // Resumo da safra
  totalArea       Float @default(0)
  totalReceita    Float @default(0)
  totalCusto      Float @default(0)
  totalResultado  Float @default(0)
  margem          Float @default(0)
  revenueHa       Float @default(0)
  resultadoHa     Float @default(0)
  totalDivida     Float @default(0)
  comprometimento Float @default(0) // dívida/receita

  // Por cultura (JSON)
  culturas  String @default("[]") // [{cultura, area, produtividade, cotacao, resultado}]

  createdAt DateTime @default(now())

  @@unique([clientId, safra])
}

// DRE Rural — demonstrativo formal do produtor
model AgroDRERural {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  safra     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  // === RECEITAS ===
  recSojaVolume      Float @default(0) // sacas vendidas
  recSojaPreco       Float @default(0) // R$/sc
  recMilhoVolume     Float @default(0)
  recMilhoPreco      Float @default(0)
  recFeijaoVolume    Float @default(0)
  recFeijaoPreco     Float @default(0)
  recOutras          Float @default(0) // outras receitas

  // === CUSTO DA ATIVIDADE (variáveis) ===
  custoAtivTotal     Float @default(0) // total R$ — campo principal do DRE
  totalAreaCusteada  Float @default(0) // ha
  // Detalhamento (R$/ha) — compõem o custo para análise
  custoSementesHa    Float @default(0)
  custoFertilizHa    Float @default(0)
  custoDefensivosHa  Float @default(0)
  custoDieselHa      Float @default(0)
  custoServicosHa    Float @default(0)
  custoOutrosHa      Float @default(0)

  // === CUSTO DE ARRENDAMENTO ===
  arrendamentoHa     Float @default(0) // R$/ha
  areaArrendada      Float @default(0)

  // === DESPESAS ADMINISTRATIVAS ===
  folha              Float @default(0)
  proLabore          Float @default(0)
  contabilidade      Float @default(0)
  energia            Float @default(0)
  internet           Float @default(0)
  manutencaoVeic     Float @default(0)
  seguros            Float @default(0)
  outrasAdmin        Float @default(0)

  // === FINANCEIRO ===
  despFinanceiras    Float @default(0) // juros pagos
  amortizacoes       Float @default(0) // amortização de principal

  // === DEPRECIAÇÃO (opcional) ===
  depreciacao        Float @default(0)

  @@unique([clientId, safra])
}

// Inadimplência PJ — aging da carteira
model PJInadimplencia {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  cliente   String   // nome do devedor
  documento String?  // CPF/CNPJ
  valor     Float
  dataVenc  DateTime
  diasAtraso Int     @default(0)
  status    String   @default("em_aberto") // em_aberto | negociando | renegociado | perdido
  obs       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// QUESTIONÁRIOS COMPLETOS
// ─────────────────────────────────────────────

// Questionário PJ — respostas armazenadas como JSON por seção
model QuestionarioPJ {
  id        String   @id @default(cuid())
  clientId  String   @unique
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Seções (JSON com perguntas e respostas de cada seção)
  identificacao   String @default("{}")
  negocio         String @default("{}")
  faturamento     String @default("{}")
  fornecedores    String @default("{}")
  estoque         String @default("{}")
  equipe          String @default("{}")
  bancos          String @default("{}")
  impostos        String @default("{}")
  gestaoFinanceira String @default("{}")
  planejamento    String @default("{}")

  // Metadados
  percentualConclusao Float   @default(0)
  dataUltimaEdicao    DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Questionário Agro
model QuestionarioAgro {
  id        String   @id @default(cuid())
  clientId  String   @unique
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  identificacao   String @default("{}")
  produtividade   String @default("{}")
  fornecedores    String @default("{}")
  prestadores     String @default("{}")
  logistica       String @default("{}")
  comercializacao String @default("{}")
  gestaoFinanceira String @default("{}")
  bancos          String @default("{}")
  patrimonio      String @default("{}")
  sucessao        String @default("{}")

  percentualConclusao Float    @default(0)
  dataUltimaEdicao    DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Metas de indicadores por cliente
model Meta {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tipo      String   // "pj" | "agro"
  indicador String   // "margLiq" | "ebitda" | "liquidezC" | "margem" etc.
  label     String
  valorMeta Float
  unidade   String   @default("%") // "%" | "x" | "R$" | "sc/ha" etc.
  prazo     DateTime
  status    String   @default("em_andamento") // "em_andamento" | "atingida" | "nao_atingida"
  obs       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// DRE Projetado PJ (orçamento anual)
model PJDreProjetado {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ano       Int
  mes       Int      // 1-12

  receitaBruta     Float @default(0)
  cmv              Float @default(0)
  despesasFixas    Float @default(0)
  folha            Float @default(0)
  proLabore        Float @default(0)
  tributos         Float @default(0)
  despFinanceiras  Float @default(0)
  parcela          Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, ano, mes])
}

// AF Gestão & Consultoria — Schema Prisma
// SQLite para desenvolvimento local | PostgreSQL para produção (Supabase)
// Troca automática via DATABASE_URL no .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("CONSULTOR")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients          Client[]          @relation("Responsible")
  diagnosticosPJ   DiagnosticoPJ[]
  diagnosticosAgro DiagnosticoAgro[]
  actionPlans      ActionPlan[]
}

model Client {
  id            String   @id @default(cuid())
  name          String
  document      String   @unique
  phone         String
  email         String
  city          String
  state         String   @default("MT")
  address       String?
  zipCode       String?
  segment       String
  size          String   @default("MEDIA")
  revenue       Float    @default(0)
  status        String   @default("LEAD")
  notes         String?
  responsibleId String
  responsible   User     @relation("Responsible", fields: [responsibleId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contacts         Contact[]
  attendances      Attendance[]
  contracts        Contract[]
  diagnosticosPJ   DiagnosticoPJ[]
  diagnosticosAgro DiagnosticoAgro[]
  actionPlans      ActionPlan[]
  creditOps        CreditOperation[]
  cashFlows        CashFlow[]
  documents        Document[]
  agroProducoes    AgroProducao[]
  agroContratos    AgroContrato[]
  agroDespesas     AgroDespesa[]
  agroReceitas     AgroReceita[]
  agroCustosFixos  AgroCustoFixo[]
  agroPatrimonios  AgroPatrimonio[]
  pjDres           PJDre[]
  pjRecebimentos   PJRecebimento[]
  pjPagamentos     PJPagamento[]
  pjContratos      PJContrato[]
  pjDespesas       PJDespesa[]
  pjReceitas       PJReceita[]
  pjCustosFixos    PJCustoFixo[]
  pjStressTests    PJStressTest[]
}

model Contact {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name     String
  role     String?
  phone    String?
  email    String?
  primary  Boolean @default(false)
}

model Attendance {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date      DateTime
  type      String
  summary   String
  nextSteps String?
  createdAt DateTime @default(now())
}

model Contract {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  plan         String
  description  String?
  monthlyValue Float
  setupFee     Float?
  startDate    DateTime
  renewalDate  DateTime
  status       String   @default("ATIVO")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DiagnosticoPJ {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  consultorId String
  consultor   User     @relation(fields: [consultorId], references: [id])
  period      String
  segment     String?
  employees   Int?

  grossRevenue      Float @default(0)
  deductions        Float @default(0)
  cmv               Float @default(0)
  fixedExpenses     Float @default(0)
  variableExpenses  Float @default(0)
  financialExpenses Float @default(0)
  proLabore         Float @default(0)
  totalDebt         Float @default(0)
  shortTermDebt     Float @default(0)
  bankName          String?

  hasAccounting       Boolean @default(false)
  hasERP              Boolean @default(false)
  hasFinancialControl Boolean @default(false)

  classification String?
  grossMargin    Float?
  netMargin      Float?
  ebitda         Float?
  breakeven      Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actionPlans ActionPlan[]
  documents   Document[]
}

model DiagnosticoAgro {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  consultorId String
  consultor   User     @relation(fields: [consultorId], references: [id])
  season      String

  ownArea      Float @default(0)
  leasedArea   Float @default(0)
  leaseValueHa Float @default(0)
  cultures     String

  custeioValue Float  @default(0)
  custeioBank  String?
  custeioRate  Float  @default(0)
  investValue  Float  @default(0)
  investBank   String?
  investRate   Float  @default(0)
  cprValue     Float  @default(0)
  cprBank      String?

  propertyValue  Float @default(0)
  machineryValue Float @default(0)

  hasInsurance     Boolean @default(false)
  hasPlanning      Boolean @default(false)
  hasFinancialCtrl Boolean @default(false)

  classification String?
  totalRevenue   Float?
  totalCost      Float?
  margin         Float?
  revenueHa      Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actionPlans ActionPlan[]
  documents   Document[]
}

model CashFlow {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  year        Int
  month       Int
  type        String
  category    String
  description String
  value       Float
  dueDate     DateTime
  paidDate    DateTime?
  status      String    @default("PENDENTE")
  createdAt   DateTime  @default(now())
}

model CreditOperation {
  id         String    @id @default(cuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id])
  bank       String
  creditLine String
  value      Float
  rate       Float
  termMonths Int
  guarantees String?
  startDate  DateTime?
  status     String    @default("ANALISE")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ActionPlan {
  id                String           @id @default(cuid())
  clientId          String
  client            Client           @relation(fields: [clientId], references: [id])
  consultorId       String
  consultor         User             @relation(fields: [consultorId], references: [id])
  diagnosticoPJId   String?
  diagnosticoPJ     DiagnosticoPJ?   @relation(fields: [diagnosticoPJId], references: [id])
  diagnosticoAgroId String?
  diagnosticoAgro   DiagnosticoAgro? @relation(fields: [diagnosticoAgroId], references: [id])

  area           String
  action         String
  objective      String
  priority       String   @default("MEDIA")
  deadline       DateTime
  responsible    String
  expectedResult String
  status         String   @default("NAO_INICIADO")
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id                String           @id @default(cuid())
  clientId          String
  client            Client           @relation(fields: [clientId], references: [id])
  diagnosticoPJId   String?
  diagnosticoPJ     DiagnosticoPJ?   @relation(fields: [diagnosticoPJId], references: [id])
  diagnosticoAgroId String?
  diagnosticoAgro   DiagnosticoAgro? @relation(fields: [diagnosticoAgroId], references: [id])
  name              String
  type              String
  url               String?
  size              Int?
  status            String   @default("RASCUNHO")
  createdAt         DateTime @default(now())
}

// ─────────────────────────────────────────────
// MÓDULO AGRO COMPLETO
// ─────────────────────────────────────────────

// Produção histórica (triênio) + previsão
model AgroProducao {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  safra     String   // ex: "2023/24", "2024/25", "2025/26"
  tipo      String   // "historico" | "previsao"
  cultura   String   // "Soja" | "Milho 2a" | "Algodao" etc
  ordem     String   // "principal" | "segunda"
  cotacao   Float    @default(0)
  area      Float    @default(0)
  produtividade Float @default(0)
  custoPorHa    Float @default(0)
  areaArrendada Float @default(0)
  custoArrendHa Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contratos de crédito individuais
model AgroContrato {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  modalidade    String   // Capital de giro, Repactuação, Investimento CDI, BNDES Finame, Custeio, CPR etc
  banco         String
  numeroContrato String?
  dataContratacao DateTime
  valorTomado   Float
  totalParcelas Int
  parcelaAtual  Int
  periodicidade String   // Mensal | Anual | Semestral | Trimestral | Único
  taxa          Float    // % ao período
  vencimento    DateTime // data do próximo vencimento
  valorParcela  Float
  obs           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Despesas não bancárias
model AgroDespesa {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  data      DateTime
  tipo      String   // Salários | Custo da atividade | Investimento | Cartão de crédito | Contas comércio | Previsões | Outros
  origem    String
  descricao String
  valor     Float
  createdAt DateTime @default(now())
}

// Receitas
model AgroReceita {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  data      DateTime
  origem    String
  tipo      String   // Recebimento | Antecipação | CPR | Outros
  descricao String
  valor     Float
  createdAt DateTime @default(now())
}

// Custos fixos por categoria
model AgroCustoFixo {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  categoria String   // Custos recorrentes | Folha | Contábil | Tecnologia | Marketing | Operacional | Bancário | Consórcios
  item      String
  valorMensal Float  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Patrimônio
model AgroPatrimonio {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  categoria     String   // Máquinas | Equipamentos | Veículos | Imóveis rurais | Imóveis urbanos | Rebanho
  descricao     String
  identificacao String?
  valorAvaliado Float    @default(0)
  possuiOnus    Boolean  @default(false)
  tipoOnus      String?
  credor        String?
  valorOnus     Float    @default(0)
  obs           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────
// MÓDULO PJ COMPLETO
// ─────────────────────────────────────────────

// Snapshot do DRE (entradas do formulário)
model PJDre {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  periodo   String   @default("mensal") // mensal | anual

  // Entradas
  receitaBruta        Float @default(0)
  cmv                 Float @default(0)
  despesasFixas       Float @default(0)
  folha               Float @default(0)
  proLabore           Float @default(0)
  tributos            Float @default(0)
  despesasFinanceiras Float @default(0)
  parcela             Float @default(0)

  // Ativos / passivos
  caixa               Float @default(0)
  aReceber            Float @default(0)
  estoque             Float @default(0)
  aFornecedores       Float @default(0)
  dividaTotal         Float @default(0)
  dividaCP            Float @default(0) // curto prazo

  // Premissas extras
  diasEstoque         Float @default(30)
  lucroInformadoSocio Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Formas de recebimento
model PJRecebimento {
  id          String  @id @default(cuid())
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  forma       String  // Boleto | Cartão débito | Cartão crédito | PIX | Dinheiro | Cheque | Crediário
  percentual  Float   @default(0) // % das vendas
  prazoMedio  Int     @default(0) // dias
  parcelas    Int     @default(1)
  obs         String?
  createdAt   DateTime @default(now())
}

// Formas de pagamento a fornecedores
model PJPagamento {
  id          String  @id @default(cuid())
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  forma       String  // Boleto/prazo | Transferência | Cartão/antecipado | À vista/PIX
  percentual  Float   @default(0)
  prazoMedio  Int     @default(0)
  parcelas    Int     @default(1)
  obs         String?
  createdAt   DateTime @default(now())
}

// Contratos PJ (mesma estrutura do Agro)
model PJContrato {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  modalidade      String
  banco           String
  numeroContrato  String?
  dataContratacao DateTime
  valorTomado     Float
  totalParcelas   Int
  parcelaAtual    Int
  periodicidade   String
  taxa            Float
  vencimento      DateTime
  valorParcela    Float
  obs             String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Despesas PJ
model PJDespesa {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  data      DateTime
  tipo      String
  origem    String
  descricao String
  valor     Float
  createdAt DateTime @default(now())
}

// Receitas PJ
model PJReceita {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  data      DateTime
  origem    String
  tipo      String
  descricao String
  valor     Float
  createdAt DateTime @default(now())
}

// Custos fixos PJ
model PJCustoFixo {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  categoria   String
  item        String
  valorMensal Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Premissas do Stress Test
model PJStressTest {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  variacaoQueda   Float    @default(-0.3)  // ex: -0.3 = -30%
  variacaoAlta    Float    @default(0.3)
  pctCustoVar     Float    @default(0.48)  // % custo variável / receita
  pctDespFixaVar  Float    @default(0.05)  // % despesa fixa que varia com vendas
  saldoInicial    Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

# Copie este arquivo para .env.production e preencha com os valores reais
# NÃO commite o arquivo .env.production no Git

NODE_ENV=production

# PostgreSQL Supabase (substitua pela sua URL)
DB_PROVIDER=postgresql
DATABASE_URL="postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres"

# JWT — gere uma chave forte: openssl rand -base64 32
JWT_SECRET="SUBSTITUA_POR_UMA_CHAVE_FORTE_E_ALEATORIA"
JWT_EXPIRES_IN="7d"

PORT=3333

# URL do frontend no Vercel (sem barra no final)
FRONTEND_URL="https://af-gestao.vercel.app"
